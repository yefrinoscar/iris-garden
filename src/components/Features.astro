---
const features = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
    </svg>`,
    title: 'Flores Frescas del Campo',
    description: 'Abastecidas diariamente de cultivadores locales y nuestros propios jardines. Cada tallo es cortado a mano en su máximo esplendor.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>`,
    title: 'Entrega el Mismo Día',
    description: 'Ordena antes de las 2pm y tu ramo llega hoy. Porque el amor no debería tener que esperar.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
    </svg>`,
    title: 'Hecho con Amor',
    description: 'Floristas expertas elaboran cada arreglo con cuidado y estilo artístico. Cada ramo cuenta una historia.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
    </svg>`,
    title: 'Empaque Ecológico',
    description: 'Empaque 100% reciclable y biodegradable. Flores hermosas, planeta hermoso.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
    </svg>`,
    title: 'Garantía de Frescura',
    description: 'Garantía de frescura de 7 días o te devolvemos tu dinero. Respondemos por cada pétalo que entregamos.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
    </svg>`,
    title: 'Soporte 24/7',
    description: 'Nuestro equipo de conserjería floral está siempre aquí para ayudarte a encontrar el arreglo perfecto.',
  },
];
---

<section id="features" class="py-20 lg:py-32 bg-white relative">
  <div class="absolute inset-0 bg-gradient-to-b from-cream to-white pointer-events-none"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 lg:mb-20">
      <span class="text-primary-600 font-semibold text-sm uppercase tracking-wider">Por Qué Elegirnos</span>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900">
        La Diferencia de Iris Garden
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        Cada detalle es cuidadosamente considerado para asegurar que tus flores lleguen perfectas y traigan alegría a quien las reciba.
      </p>
    </div>

    <!-- Features Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
      {features.map((feature) => (
        <div class="group relative bg-cream rounded-3xl p-8 hover:bg-white hover:shadow-xl hover:shadow-primary-100/50 transition-all duration-300 hover:-translate-y-1 border border-transparent hover:border-primary-100">
          <div class="w-14 h-14 bg-primary-100 group-hover:bg-primary-500 text-primary-600 group-hover:text-white rounded-2xl flex items-center justify-center transition-colors duration-300" set:html={feature.icon}>
          </div>
          <h3 class="mt-6 font-display text-xl font-semibold text-gray-900">{feature.title}</h3>
          <p class="mt-3 text-gray-600 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
