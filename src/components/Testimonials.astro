---
const testimonials = [
  {
    name: 'Sarah Mitchell',
    role: 'Suscriptora de Floración',
    avatar: '👩🏻',
    rating: 5,
    text: 'Mi madre llora de alegría cada vez que llega su ramo mensual. La calidad es excepcional y los arreglos siempre son impresionantes. ¡La mejor suscripción que he regalado!',
  },
  {
    name: 'James Rodriguez',
    role: 'Suscriptor de Jardín',
    avatar: '👨🏽',
    rating: 5,
    text: 'Le envío flores a mi esposa cada semana a través de El Jardín de Iris. El plan Jardín vale cada centavo: ¡los floreros de diseñador son hermosos y las flores duran más de una semana!',
  },
  {
    name: 'Emily Chen',
    role: 'Suscriptora de Pétalo',
    avatar: '👩🏻‍🦰',
    rating: 5,
    text: 'Como alguien que no es buena recordando fechas especiales, esta suscripción es un salvavidas. Flores frescas y hermosas cada mes sin tener que pensar en ello.',
  },
  {
    name: 'Michael Thompson',
    role: 'Suscriptor de Floración',
    avatar: '👨🏼',
    rating: 5,
    text: '¡La entrega el mismo día no es broma! Olvidé nuestro aniversario y El Jardín de Iris me salvó el día. ¡Un hermoso ramo llegó en horas. Mi esposa estaba encantada!',
  },
  {
    name: 'Lisa Park',
    role: 'Suscriptora de Jardín',
    avatar: '👩🏾',
    rating: 5,
    text: 'Dirijo un pequeño café y los ramos semanales de El Jardín de Iris hacen que nuestro espacio sea muy acogedor. ¡Los clientes siempre elogian las flores. ¡Se han convertido en parte de nuestra marca!',
  },
  {
    name: 'David Kim',
    role: 'Suscriptor de Pétalo',
    avatar: '👨🏻',
    rating: 5,
    text: 'Comencé con el plan Pétalo para animar a mi novia durante los exámenes. Ahora es algo permanente porque le encanta mucho. Las flores siempre están frescas y fragantes.',
  },
];
---

<section id="testimonials" class="py-20 lg:py-32 bg-gradient-to-br from-primary-50 via-rose-soft to-cream relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-primary-200/30 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-accent-200/30 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-primary-600 font-semibold text-sm uppercase tracking-wider">Testimonios</span>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900">
        Amado por Miles
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        No solo tomes nuestra palabra. Esto es lo que dicen nuestros clientes felices.
      </p>

      <!-- Rating Summary -->
      <div class="mt-8 inline-flex items-center gap-3 bg-white rounded-full px-6 py-3 shadow-sm">
        <div class="flex gap-0.5">
          <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        </div>
        <span class="font-semibold text-gray-900">4.9/5</span>
        <span class="text-gray-500">de más de 12,000 reseñas</span>
      </div>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-white rounded-3xl p-8 shadow-sm hover:shadow-lg transition-shadow">
          <!-- Rating -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: testimonial.rating }).map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          
          <!-- Text -->
          <p class="text-gray-700 leading-relaxed mb-6">"{testimonial.text}"</p>
          
          <!-- Author -->
          <div class="flex items-center gap-3 pt-6 border-t border-gray-100">
            <span class="text-3xl">{testimonial.avatar}</span>
            <div>
              <div class="font-semibold text-gray-900">{testimonial.name}</div>
              <div class="text-sm text-gray-500">{testimonial.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
