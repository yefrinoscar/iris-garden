---
const navLinks = [
  { href: '#how-it-works', label: 'Cómo Funciona' },
  { href: '#plans', label: 'Planes' },
  { href: '#features', label: 'Por Qué Elegirnos' },
  { href: '#testimonials', label: 'Testimonios' },
  { href: '#faq', label: 'Preguntas Frecuentes' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-cream/80 backdrop-blur-md border-b border-primary-100/50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <svg class="w-8 h-8 text-primary-500 group-hover:text-primary-600 transition-colors" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M16 4C14 8 8 10 8 16C8 22 12 28 16 28C20 28 24 22 24 16C24 10 18 8 16 4Z" fill="currentColor" opacity="0.2"/>
          <path d="M16 4C14 8 8 10 8 16C8 22 12 28 16 28C20 28 24 22 24 16C24 10 18 8 16 4Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M16 12C15 14 13 15 13 18C13 21 14.5 24 16 24C17.5 24 19 21 19 18C19 15 17 14 16 12Z" fill="currentColor"/>
          <path d="M16 28V20" stroke="currentColor" stroke-width="2"/>
        </svg>
        <span class="font-display text-xl font-semibold text-gray-900">Iris Garden</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a href={link.href} class="text-gray-600 hover:text-primary-600 font-medium transition-colors">
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA Button -->
      <div class="flex items-center gap-4">
        <a href="#plans" class="hidden sm:inline-flex items-center px-5 py-2.5 bg-primary-500 hover:bg-primary-600 text-white font-medium rounded-full transition-all hover:shadow-lg hover:shadow-primary-500/25">
          Enviar Flores
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-600 hover:text-primary-600">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-3 pt-4 border-t border-primary-100/50">
        {navLinks.map((link) => (
          <a href={link.href} class="text-gray-600 hover:text-primary-600 font-medium py-2 transition-colors">
            {link.label}
          </a>
        ))}
        <a href="#plans" class="inline-flex items-center justify-center px-5 py-2.5 bg-primary-500 hover:bg-primary-600 text-white font-medium rounded-full transition-all mt-2">
          Enviar Flores
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Close mobile menu when clicking a link
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>
