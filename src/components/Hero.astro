---
const stats = [
  { icon: '🌸', value: '2,847', label: 'Suscriptores activos', sublabel: 'en Lima Metropolitana' },
  { icon: '💐', value: '18,500+', label: 'Ramos entregados', sublabel: 'desde 2023' },
  { icon: '⭐', value: '4.9/5', label: 'Rating promedio', sublabel: 'en Google Reviews' },
  { icon: '🔄', value: '94%', label: 'Renuevan su plan', sublabel: 'cada mes' },
];
---

<section class="relative min-h-screen flex items-center pt-20 overflow-hidden">
  <!-- Background Decorations -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-20 left-10 w-72 h-72 bg-primary-200/30 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent-200/30 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-rose-soft/50 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-20 relative">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Hero Content -->
      <div class="text-center lg:text-left order-2 lg:order-1">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary-100 text-primary-700 rounded-full text-sm font-medium mb-6">
          <span class="w-2 h-2 bg-primary-500 rounded-full animate-pulse"></span>
          Flores frescas entregadas hoy
        </div>

        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-gray-900 leading-tight">
          Envía Amor con
          <span class="block bg-gradient-to-r from-primary-500 via-rose-gold to-primary-600 bg-clip-text text-transparent">
            Cada Pétalo
          </span>
        </h1>

        <p class="mt-6 text-lg sm:text-xl text-gray-600 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          Ramos artesanales hechos con amor, entregados frescos en tu puerta.
          Haz el día de alguien inolvidable con el regalo de las flores hermosas.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="#plans" class="inline-flex items-center justify-center px-8 py-4 bg-primary-500 hover:bg-primary-600 text-white font-semibold rounded-full transition-all hover:shadow-xl hover:shadow-primary-500/30 hover:-translate-y-0.5 text-lg">
            Explorar Planes
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a href="#how-it-works" class="inline-flex items-center justify-center px-8 py-4 bg-white hover:bg-gray-50 text-gray-800 font-semibold rounded-full border-2 border-gray-200 transition-all hover:border-primary-300 hover:shadow-lg text-lg">
            Cómo Funciona
          </a>
        </div>

        <!-- Stats -->
        <div class="mt-12 bg-white/60 backdrop-blur-sm rounded-2xl p-6 border border-gray-200/50">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-5">
            {stats.map((stat) => (
              <div class="text-center">
                <div class="text-2xl mb-1">{stat.icon}</div>
                <div class="font-display text-xl sm:text-2xl font-bold text-gray-900">{stat.value}</div>
                <div class="text-xs sm:text-sm font-medium text-gray-700 mt-1">{stat.label}</div>
                <div class="text-xs text-gray-400">{stat.sublabel}</div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Hero Image -->
      <div class="order-1 lg:order-2 relative">
        <div class="relative aspect-square max-w-lg mx-auto">
          <!-- Decorative circles -->
          <div class="absolute inset-4 bg-gradient-to-br from-primary-200 to-primary-300 rounded-full opacity-50 blur-xl"></div>
          <div class="absolute inset-8 bg-gradient-to-br from-primary-100 to-rose-soft rounded-full"></div>
          
          <!-- Main flower illustration -->
          <div class="absolute inset-12 flex items-center justify-center">
            <svg class="w-full h-full" viewBox="0 0 300 300" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Background petals -->
              <ellipse cx="150" cy="100" rx="45" ry="65" fill="#f9a8d4" opacity="0.6" transform="rotate(-15 150 100)"/>
              <ellipse cx="150" cy="100" rx="45" ry="65" fill="#f9a8d4" opacity="0.6" transform="rotate(15 150 100)"/>
              <ellipse cx="150" cy="100" rx="45" ry="65" fill="#f9a8d4" opacity="0.6" transform="rotate(45 150 100)"/>
              <ellipse cx="150" cy="100" rx="45" ry="65" fill="#f9a8d4" opacity="0.6" transform="rotate(-45 150 100)"/>
              <ellipse cx="150" cy="100" rx="45" ry="65" fill="#f9a8d4" opacity="0.6" transform="rotate(75 150 100)"/>
              <ellipse cx="150" cy="100" rx="45" ry="65" fill="#f9a8d4" opacity="0.6" transform="rotate(-75 150 100)"/>
              
              <!-- Inner petals -->
              <ellipse cx="150" cy="110" rx="30" ry="45" fill="#f472b6" opacity="0.8" transform="rotate(-10 150 110)"/>
              <ellipse cx="150" cy="110" rx="30" ry="45" fill="#f472b6" opacity="0.8" transform="rotate(10 150 110)"/>
              <ellipse cx="150" cy="110" rx="30" ry="45" fill="#f472b6" opacity="0.8" transform="rotate(35 150 110)"/>
              <ellipse cx="150" cy="110" rx="30" ry="45" fill="#f472b6" opacity="0.8" transform="rotate(-35 150 110)"/>
              <ellipse cx="150" cy="110" rx="30" ry="45" fill="#f472b6" opacity="0.8" transform="rotate(60 150 110)"/>
              <ellipse cx="150" cy="110" rx="30" ry="45" fill="#f472b6" opacity="0.8" transform="rotate(-60 150 110)"/>
              
              <!-- Center -->
              <circle cx="150" cy="120" r="25" fill="#fef08a"/>
              <circle cx="150" cy="120" r="18" fill="#fde047"/>
              <circle cx="150" cy="120" r="10" fill="#eab308"/>
              
              <!-- Stem -->
              <path d="M150 170 C150 220 145 260 140 290" stroke="#22c55e" stroke-width="8" stroke-linecap="round"/>
              
              <!-- Leaves -->
              <path d="M148 210 C120 195 95 200 85 215 C100 210 125 208 148 218" fill="#4ade80"/>
              <path d="M146 240 C170 225 195 230 205 245 C190 240 165 238 146 248" fill="#4ade80"/>
              
              <!-- Small flowers around -->
              <circle cx="80" cy="150" r="12" fill="#fbcfe8"/>
              <circle cx="80" cy="150" r="6" fill="#f9a8d4"/>
              <circle cx="220" cy="130" r="10" fill="#fbcfe8"/>
              <circle cx="220" cy="130" r="5" fill="#f9a8d4"/>
              <circle cx="100" cy="80" r="8" fill="#fbcfe8"/>
              <circle cx="100" cy="80" r="4" fill="#f9a8d4"/>
            </svg>
          </div>
          
          <!-- Floating badges -->
          <div class="absolute top-4 right-4 bg-white rounded-2xl shadow-lg px-4 py-3 flex items-center gap-2 animate-bounce">
            <span class="text-2xl">💐</span>
            <span class="font-medium text-gray-800 text-sm">Frescas Diarias</span>
          </div>
          <div class="absolute bottom-8 left-4 bg-white rounded-2xl shadow-lg px-4 py-3 flex items-center gap-2">
            <span class="text-2xl">🚚</span>
            <span class="font-medium text-gray-800 text-sm">Entrega Gratis</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
